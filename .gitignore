.claude/

# logbook recorder — host-matched ffmpeg and content-hashed narration clips are
# machine-/content-specific, provisioned by `logbook --setup`; don't commit them.
.armada/logbook/bin/
.armada/logbook/cache/

# cartographer — per-repo learned heuristics are local working state, not part of
# the distributed plugin; keep ARMADA's own cartography out of the product repo.
.armada/cartography/

# foghorn — hash-cached spoken clips are machine-/content-specific scratch, keyed
# by (text + voice + provider); regenerated on demand, never part of the plugin.
.armada/foghorn/cache/
